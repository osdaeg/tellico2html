# Tellico2HTML - Configuracion
# Copiar como .env y completar los valores

# Gotify
GOTIFY_URL=http://192.168.88.100:8088
GOTIFY_TOKEN=TuTokenDeGotify

# Red / Nginx
SERVER_IP=192.168.88.100
NGINX_PORT=8079

# Puertos del contenedor
TELLICO2HTML_INTERNAL_PORT=8000
TELLICO2HTML_EXTERNAL_PORT=7995

# Tema visual: industrial | futurista | antiguo
THEME=industrial

# Base de datos Tellico
TELLICOPATH=/libros
TELLICODB=Libros.tc

# Forzar regeneracion de todas las fichas al iniciar
FORCE_REGEN=false

# APIs de enriquecimiento
GOOGLE_BOOKS_API_KEY=TuAPIKeyDeGoogleBooks
HARDCOVER_API_KEY=TuExtremadamenteLargoTokenDeHardcover
# OpenLibrary no requiere key
OPENLIBRARY_ENABLED=true
